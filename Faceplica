# Faceplica — libdelphi.a
# Oraculum cum provisoribus et metamorphota omphalos.

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -O2
AR      ?= ar
ARFLAGS = rcs

PREFIX = /opt/apotheca
INCP    = -I. -I$(PREFIX)/include/phantasma -I$(PREFIX)/include/crispus -I$(PREFIX)/include/ison

FONTES  = oraculum.c utilia.c \
          openai.c anthropic.c xai.c fictus.c omphalos.c \
          omphalos/δρόμος.c omphalos/λεκτήρ.c \
          omphalos/ἄσκησις.c \
          eikon/δίκτυον.c eikon/ἄσκησις.c

CAPITA  = oraculum.h provisor.h utilia.h omphalos.h \
          omphalos/λεκτήρ.h omphalos/ὀμφαλός.h \
          eikon/εἰκών.h

OBIECTA = oraculum.o utilia.o \
          openai.o anthropic.o xai.o fictus.o omphalos.o \
          omphalos/δρόμος.o omphalos/λεκτήρ.o \
          omphalos/ἄσκησις.o \
          eikon/δίκτυον.o eikon/ἄσκησις.o

BIBLIOTHECA = libdelphi.a

omnia: $(BIBLIOTHECA) fare

$(BIBLIOTHECA): $(OBIECTA)
	$(AR) $(ARFLAGS) $@ $^

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) -c -o $@ $<

omphalos/%.o: omphalos/%.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) -c -o $@ $<

eikon/%.o: eikon/%.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) -c -o $@ $<

fare: fare.c $(BIBLIOTHECA) $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

exercita: exercita.c $(BIBLIOTHECA) $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
	    `cat $(PREFIX)/lib/nexus_phantasma` -lm -o $@

exercita_eikon: exercita_eikon.c $(BIBLIOTHECA) $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
	    `cat $(PREFIX)/lib/nexus_phantasma` -lm -o $@

genera_eikon: genera_eikon.c $(BIBLIOTHECA) $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
	    `cat $(PREFIX)/lib/nexus_phantasma` -lm -o $@

proba_eikon: proba_eikon.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
	    `cat $(PREFIX)/lib/nexus_phantasma` -lm -o $@

proba_omphalos: proba_omphalos.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
	    `cat $(PREFIX)/lib/nexus_phantasma` -lm -o $@

NEXUS_PROV = $(BIBLIOTHECA) $(PREFIX)/lib/libphantasma.a \
             $(PREFIX)/lib/libison.a $(PREFIX)/lib/libcrispus.a \
             `cat $(PREFIX)/lib/nexus_phantasma`

proba_fare: proba_fare.c fare $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< -o $@

proba: proba_omphalos proba_fare proba_fictus proba_openai proba_anthropic proba_xai
	./proba_fictus
	./proba_openai
	./proba_xai
	./proba_anthropic
	./proba_omphalos
	./proba_fare

proba_openai: proba_openai.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_xai: proba_xai.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_anthropic: proba_anthropic.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_fictus: proba_fictus.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/delphi/omphalos
	install -m 755 fare $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 oraculum.h provisor.h utilia.h omphalos.h $(PREFIX)/include/delphi/
	install -m 644 omphalos/λεκτήρ.h omphalos/ὀμφαλός.h $(PREFIX)/include/delphi/omphalos/

purga:
	rm -f $(OBIECTA) $(BIBLIOTHECA) fare exercita \
	    exercita_eikon genera_eikon \
	    proba_omphalos proba_openai proba_xai proba_anthropic proba_fictus proba_fare \
	    omphalos_dieta_1526.bin omphalos_dieta_1526.lex

linte:
	insinulint -c $(FONTES) $(CAPITA)

.PHONY: omnia colloca purga linte proba
