# Faceplica — libdelphi.a
# Oraculum cum provisoribus et metamorphota omphalos.

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -O2
AR      ?= ar
ARFLAGS = rcs

INCP    = -I. -Icrispus -Iison -Iomphalos

FONTES  = oraculum.c utilia.c \
          openai.c anthropic.c xai.c fictus.c \
          omphalos/δρόμος.c omphalos/λεκτήρ.c \
          omphalos/ἄσκησις.c omphalos/χορηγός.c

CAPITA  = oraculum.h provisor.h utilia.h \
          omphalos/λεκτήρ.h omphalos/ὀμφαλός.h

OBIECTA = oraculum.o utilia.o \
          openai.o anthropic.o xai.o fictus.o \
          omphalos/δρόμος.o omphalos/λεκτήρ.o \
          omphalos/ἄσκησις.o omphalos/χορηγός.o

BIBLIOTHECA = libdelphi.a

omnia: $(BIBLIOTHECA) fare

$(BIBLIOTHECA): $(OBIECTA)
	$(AR) $(ARFLAGS) $@ $^

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) -c -o $@ $<

omphalos/%.o: omphalos/%.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) -c -o $@ $<

fare: fare.c $(BIBLIOTHECA) $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_omphalos: proba_omphalos.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(BIBLIOTHECA) phantasma/libphantasma.a \
	    `cat phantasma/nexus_phantasma` -lm -o $@

NEXUS_PROV = $(BIBLIOTHECA) phantasma/libphantasma.a \
             ison/libison.a crispus/libcrispus.a \
             `cat phantasma/nexus_phantasma`

proba_fare: proba_fare.c fare $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< -o $@

proba: proba_omphalos proba_fare
	./proba_fictus
	./proba_openai
	./proba_xai
	./proba_anthropic
	./proba_omphalos
	./proba_fare

proba_openai: proba_openai.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_xai: proba_xai.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_anthropic: proba_anthropic.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

proba_fictus: proba_fictus.c $(CAPITA)
	$(CC) $(CFLAGS) $(INCP) $< $(NEXUS_PROV) -o $@

purga:
	rm -f $(OBIECTA) $(BIBLIOTHECA) fare \
	    proba_omphalos proba_openai proba_xai proba_anthropic proba_fictus proba_fare \
	    omphalos_dieta_1526.bin omphalos_dieta_1526.lex

linte:
	insinulint -c $(FONTES) $(CAPITA)

.PHONY: omnia purga linte proba
