# Faceplica — libdelphi.a
# Oraculum cum provisoribus et metamorphota omphalos.

PREFIX       = /opt/apotheca

FONTES       = oraculum.c utilia.c \
               openai.c anthropic.c xai.c fictus.c omphalos.c \
               omphalos/δρόμος.c omphalos/λεκτήρ.c \
               omphalos/ἄσκησις.c \
               eikon/δίκτυον.c eikon/ἄσκησις.c

CAPITA       = oraculum.h provisor.h utilia.h omphalos.h \
               omphalos/λεκτήρ.h omphalos/ὀμφαλός.h \
               eikon/εἰκών.h

OBJECTA      = $(FONTES:.c=.o)

BIBLIOTHECA  = libdelphi.a

LIBISON      = $(PREFIX)/lib/libison.a
LIBCRISPUS   = $(PREFIX)/lib/libcrispus.a
LIBPHANTASMA = $(PREFIX)/lib/libphantasma.a
NEXUSPH      = `cat $(PREFIX)/lib/nexus_phantasma`

omnia: $(BIBLIOTHECA) fare exercita exercita_eikon genera_eikon

%.o: %.c $(CAPITA)
	ccc -I $(PREFIX)/include $<
	# cc -I $(PREFIX)/include -c -o $@ $<

$(BIBLIOTHECA): $(OBJECTA)
	ar rcs $@ $^

fare: fare.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

exercita: exercita.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

exercita_eikon: exercita_eikon.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

genera_eikon: genera_eikon.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_omphalos: proba_omphalos.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_eikon: proba_eikon.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_openai: proba_openai.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_xai: proba_xai.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_anthropic: proba_anthropic.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_fictus: proba_fictus.o $(BIBLIOTHECA) $(LIBPHANTASMA) $(LIBISON) $(LIBCRISPUS)
	ldi $(NEXUSPH) $^

proba_fare: proba_fare.o
	ldi proba_fare.o

proba: proba_omphalos proba_fare proba_fictus proba_openai proba_anthropic proba_xai
	./proba_fictus
	./proba_openai
	./proba_xai
	./proba_anthropic
	./proba_omphalos
	./proba_fare

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/delphi/omphalos $(PREFIX)/include/delphi/eikon
	install -m 755 fare $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 oraculum.h provisor.h utilia.h omphalos.h $(PREFIX)/include/delphi/
	install -m 644 omphalos/λεκτήρ.h omphalos/ὀμφαλός.h $(PREFIX)/include/delphi/omphalos/
	install -m 644 eikon/εἰκών.h $(PREFIX)/include/delphi/eikon/

purga:
	rm -f $(OBJECTA) $(BIBLIOTHECA) fare exercita exercita_eikon genera_eikon
	rm -f fare.o exercita.o exercita_eikon.o genera_eikon.o
	rm -f proba_omphalos proba_eikon proba_openai proba_xai proba_anthropic proba_fictus proba_fare
	rm -f proba_omphalos.o proba_eikon.o proba_openai.o proba_xai.o proba_anthropic.o proba_fictus.o proba_fare.o
	rm -f omphalos_dieta_1526.bin

linte:
	insinulint -c $(FONTES) $(CAPITA)

.PHONY: omnia colloca purga proba linte
